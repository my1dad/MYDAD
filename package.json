{
  "name": "over-drive-os",
  "private": true,
  "version": "1.0.0",
  "description": "Over Drive OS — project roadmap dashboard",
  "author": "Over Drive",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host --port 5173",
    "dev:clean": "lsof -ti:5173 | xargs kill -9 2>/dev/null || true; vite --host --port 5173",
    "dev:open": "vite --host --port 5173 --open /roadmap.html",
    "dev:preloader": "vite --host --port 5173 --open /preloader-dev.html",
    "fresh-dashboard": "node scripts/fresh-dashboard.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "icons": "bash scripts/generate-mac-icon.sh",
    "dmg:icons": "bash scripts/generate-dmg-icon.sh",
    "electron:pack": "npm run build && npm run icons && electron-builder --mac dir",
    "electron:dmg": "bash scripts/create-dmg.sh",
    "electron:build": "npm run electron:pack && npm run electron:dmg"
  },
  "build": {
    "appId": "os.overdrive.app",
    "productName": "Over Drive OS",
    "directories": {
      "output": "."
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "bins/**/.gitkeep",
      "bins/README.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "icon": "build/icon.icns",
      "identity": null
    },
    "dmg": {
      "title": "Over Drive OS",
      "icon": "build/icon.icns",
      "iconSize": 160
    }
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  }
}
